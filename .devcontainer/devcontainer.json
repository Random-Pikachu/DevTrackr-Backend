{
  "name": "DevTrackr Backend",
  "dockerComposeFile": "docker-compose.yml",
  "service": "app",
  "workspaceFolder": "/workspace",
  "forwardPorts": [8080, 5432],
  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ]
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "go mod tidy"
}